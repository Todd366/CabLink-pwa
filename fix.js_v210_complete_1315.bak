console.log("🔥 CabLink fix.js v210 - Improved Accurate Simulation");

document.addEventListener('DOMContentLoaded', function() {

  // Locked Dark Theme
  const theme = document.createElement('style');
  theme.innerHTML = `
    body, html, #app, .screen, .card, .modal, input, select, button, .statusbar {
      background: #0a0a0f !important;
      color: #f0f0f5 !important;
    }
    .btn-primary, #bookBtn, button[class*="btn-primary"] {
      background: #f5c518 !important;
      color: #000 !important;
      font-weight: bold !important;
    }
  `;
  document.head.appendChild(theme);

  // Clean Profile
  function cleanProfile() {
    const nameEl = document.querySelector('#s-profile .card-title');
    const subEl = document.querySelector('#s-profile .card-sub');
    if (nameEl) nameEl.textContent = "Connected User";
    if (subEl) subEl.textContent = "BSTM Member • Gaborone";
  }
  cleanProfile();

  // Improved Realistic Booking with Distance & Cost
  window.bookRide = function() {
    const pickup = (document.getElementById('pickup') || {}).value?.trim() || "BSTM HQ, Mmopane";
    const dropoff = (document.getElementById('dropoff') || {}).value?.trim() || "Game City Mall";

    toast("🔍 Searching for drivers near " + pickup + "...", "info");

    setTimeout(() => {
      const distance = "6.8 km";
      const estimatedCost = "38 BWP";
      const driverName = "Driver near you";

      toast("🚕 Driver found! " + distance + " away • Est. " + estimatedCost, "success");

      setTimeout(() => {
        toast("Driver " + driverName + " is on the way. ETA \~9 minutes.", "success");
      }, 2500);
    }, 1800);
  };

  // Final Cleanup
  setTimeout(() => {
    const fakes = ['chatSection','rideIdRow','countdownRow','cancelBtn','driverChat','rideStatusLabel','progressBar'];
    fakes.forEach(id => {
      const el = document.getElementById(id);
      if (el) el.style.display = 'none';
    });
  }, 800);

  console.log("✅ v210 - Improved Accurate Simulation Ready");
});
