console.log("🔥 CabLink fix.js v90 - Strong Restore");

document.addEventListener('DOMContentLoaded', function() {
  // === FORCE DARK THEME ===
  const theme = document.createElement('style');
  theme.innerHTML = `
    body, html, #app, .screen, .card, .modal, input, select, button {
      background: #0a0a0f !important;
      color: #f0f0f5 !important;
    }
    .btn-primary, button[class*="btn-primary"], .yellow-btn {
      background: #f5c518 !important;
      color: #000 !important;
      font-weight: bold !important;
    }
    .statusbar, .card { border-color: #2a2a3e !important; }
  `;
  document.head.appendChild(theme);

  // === CLEAN PROFILE (no hardcoded name) ===
  function cleanProfile() {
    const nameEl = document.querySelector('#s-profile .card-title');
    const subEl = document.querySelector('#s-profile .card-sub');
    if (nameEl) nameEl.textContent = "Connected User";
    if (subEl) subEl.textContent = "BSTM Member • Gaborone";
  }
  cleanProfile();

  // === ROLE SWITCHER (if not already there) ===
  // ... (your v66 role badge code can stay, but we'll keep it simple)

  // === HIDE FAKE RIDE ELEMENTS ===
  setTimeout(() => {
    const fakes = ['chatSection','rideIdRow','countdownRow','cancelBtn','driverChat','rideStatusLabel'];
    fakes.forEach(id => {
      const el = document.getElementById(id);
      if (el) el.style.display = 'none';
    });
  }, 800);

  console.log("✅ v90 Strong Restore Applied");
});
